{
  "name": "memory-pet-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A privacy-first desktop pet agent with tiered memory, heartbeat reflection, proactive chat and voice interaction.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MonsterN58/memory-pet-agent.git"
  },
  "homepage": "https://github.com/MonsterN58/memory-pet-agent#readme",
  "bugs": {
    "url": "https://github.com/MonsterN58/memory-pet-agent/issues"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "tsx --test --test-isolation=none tests/*.test.ts",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "smoke": "npm run build && electron . --smoke-test --user-data-dir=./output/smoke-data",
    "smoke:voice": "npm run build && electron scripts/local-asr-smoke.cjs",
    "smoke:model-switch": "npm run build && electron . --model-switch-smoke --user-data-dir=./output/model-switch-smoke-data",
    "voice:model:download": "node scripts/download-asr-model.mjs",
    "voice:model:verify": "node scripts/download-asr-model.mjs --verify-only",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "pixi.js": "8.13.1",
    "sherpa-onnx": "1.13.4",
    "untitled-pixi-live2d-engine": "1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "43.1.0",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "cn.memorypet.agent",
    "productName": "记忆桌宠",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "THIRD_PARTY_NOTICES.md"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
